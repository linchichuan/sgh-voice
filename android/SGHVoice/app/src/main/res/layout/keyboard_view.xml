<?xml version="1.0" encoding="utf-8"?>
<!-- 輸入法鍵盤佈局：麥克風按鈕 + 狀態文字 + 功能鍵 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg"
    android:padding="8dp">

    <!-- 上方區域：狀態文字 + 麥克風按鈕 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <!-- 大型麥克風按鈕 -->
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/mic_button_bg"
            android:contentDescription="@string/mic_button_desc"
            android:scaleType="centerInside"
            android:padding="20dp" />

        <!-- 狀態文字 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="@color/status_text"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- 下方功能鍵列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="8dp">

        <!-- 退格鍵 -->
        <TextView
            android:id="@+id/btn_backspace"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="@string/key_backspace"
            android:textSize="16sp"
            android:textColor="@color/key_text"
            android:background="@drawable/key_bg"
            android:layout_marginEnd="4dp" />

        <!-- 空白鍵 -->
        <TextView
            android:id="@+id/btn_space"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="@string/key_space"
            android:textSize="14sp"
            android:textColor="@color/key_text"
            android:background="@drawable/key_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 換行鍵 -->
        <TextView
            android:id="@+id/btn_enter"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="@string/key_enter"
            android:textSize="16sp"
            android:textColor="@color/key_text_enter"
            android:background="@drawable/key_enter_bg"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</LinearLayout>
